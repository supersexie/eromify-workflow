OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
FAL_KEY=...

# Content moderation (lib/moderation.js) — required for every generation
# route to work; they fail closed (block) without it, not silently skip.
# This is a Hive V3 *Secret Key* (Bearer auth) from thehive.ai → Playground
# API Keys (the Secret Key, NOT the Access Key ID). One key covers both models
# used: hive/visual-moderation and hive/ai-generated-and-deepfake-content-detection.
HIVE_API_KEY=...

# Known-CSAM hash matching baseline (Thorn Safer / Microsoft PhotoDNA) — not
# wired into lib/moderation.js yet. Requires a gated partnership/approval
# process, not a self-serve key. See MODERATION.md.
# SAFER_API_KEY=...

# --- Google OAuth (Auth.js) ---
# Create an OAuth client in Google Cloud Console → APIs & Services → Credentials.
# Authorized redirect URI: https://www.magicmint.pro/api/auth/callback/google
# (and http://localhost:3000/api/auth/callback/google for local).
# Omit these → app stays open (no login required).
AUTH_SECRET=                    # openssl rand -base64 32
AUTH_GOOGLE_ID=                 # Google OAuth client ID
AUTH_GOOGLE_SECRET=             # Google OAuth client secret
